{
  "service": "EstateOS Unified Intelligence API",
  "version": "1.0.0",
  "azure_pattern": {
    "entrypoints": [
      "Azure API Management",
      "Azure Front Door",
      "Private endpoints"
    ],
    "runtime": [
      "Azure Kubernetes Service",
      "Azure Container Apps",
      "Azure Functions"
    ],
    "data": [
      "Azure SQL",
      "Cosmos DB",
      "Data Lake Storage Gen2",
      "Azure AI Search"
    ],
    "security": [
      "Microsoft Entra External ID",
      "Key Vault",
      "Defender for Cloud",
      "Microsoft Purview",
      "Microsoft Sentinel"
    ]
  },
  "identity_and_access": {
    "frontend_capture": [
      "investor_type",
      "location",
      "financial_intent",
      "residency_goal",
      "consent_scope",
      "privacy_preferences",
      "deal_participants",
      "transaction_stage",
      "payment_method_type",
      "escrow_preference",
      "payment_schedule"
    ],
    "trust_controls": [
      "OIDC/OAuth2 with step-up MFA",
      "RBAC plus entitlement checks",
      "KYC status propagation",
      "AML risk scoring",
      "sanctions screening status",
      "purpose-bound privacy tiers",
      "segregation of duties for approvals"
    ],
    "router_contract": {
      "required_headers": [
        "Authorization",
        "x-correlation-id",
        "x-journey-stage",
        "x-transaction-id",
        "x-partner-system"
      ],
      "required_context": [
        "subject_id",
        "auth_assurance_level",
        "mfa_completed",
        "rbac_roles",
        "entitlements",
        "kyc_status",
        "aml_risk",
        "sanctions_status",
        "privacy_tier",
        "payment_token_scope",
        "escrow_role",
        "settlement_permissions",
        "partner_id",
        "integration_profile",
        "data_classification"
      ]
    }
  },
