  "endpoints": [
    {
      "path": "/v1/identity/profile-context",
      "method": "POST",
      "purpose": "Capture frontend profile, privacy, and trust context before MoE routing.",
      "controls": [
        "OIDC session binding",
        "step-up MFA",
        "consent receipt",
        "PII classification",
        "audit log"
      ]
    },
    {
      "path": "/v1/intelligence/route",
      "method": "POST",
      "purpose": "Detect user intent and select MoE experts using profile and identity trust context.",
      "controls": [
        "JWT auth",
        "RBAC",
        "entitlement check",
        "PII minimization",
        "audit log",
        "ranked expert contribution trace"
      ]
    },
    {
      "path": "/v1/documents/intelligence/reason",
      "method": "POST",
      "purpose": "Extract, validate, summarize, and reason over contracts, title packets, insurance policies, and immigration evidence while keeping anomaly detection, compliance checks, and full audit trails on the backend.",
      "controls": [
        "blob hash and provenance tracking",
        "field-level confidence and normalization evidence",
        "cross-document anomaly detection",
        "legal/compliance review gating",
        "immutable audit trail"
      ]
    },
    {
      "path": "/v1/copilot/conversations/respond",
      "method": "POST",
      "purpose": "Run the multi-role conversational copilot so buyers, investors, insurance users, visa applicants, and compliance reviewers can query MoE decisions in natural language with context memory and explainable role-specific reasoning.",
      "controls": [
        "role-aware prompt routing",
        "short-term memory minimization",
        "explainability trace attachment",
        "privacy tier enforcement",
        "audit logging for each response turn",
        "compliance-gated response shaping"
      ]
    },
    {
      "path": "/v1/trust/reputation/score",
      "method": "POST",
      "purpose": "Score user, property, broker, and transaction trust using historical behavior, verification posture, AI risk indicators, and compliance graph data so the frontend can render trust signals while the backend continuously re-evaluates risk.",
      "controls": [
        "entity-level explainability payload",
        "continuous rescoring trigger policy",
        "KYC/AML and sanctions context binding",
        "privacy-tier aware signal redaction",
        "human-review escalation thresholds",
        "auditable score history ledger"
      ]
    },
    {
      "path": "/v1/integrations/hub/route",
      "method": "POST",
      "purpose": "Validate, transform, and route external banking, insurance, and government payloads through AI experts before partner or internal-system delivery.",
      "controls": [
        "canonical schema validation",
        "mTLS and signed service identity",
        "partner entitlement check",
        "policy-bound field minimization",
        "interoperability evidence ledger"
      ]
    },
    {
      "path": "/v1/compliance/risk-intelligence/monitor",
      "method": "POST",
      "purpose": "Continuously evaluate platform activity across real estate, payments, insurance, and residency workflows while enforcing AML/KYC, sanctions screening, audit logging, and cross-domain risk scoring.",
      "controls": [
        "continuous AML/KYC posture checks",
        "real-time sanctions and PEP screening linkage",
        "immutable audit event chain",
        "ISO/IEC 27001 control mapping",
        "ISO 31000 risk treatment workflow"
      ]
    },
    {
      "path": "/v1/properties/recommendations",
      "method": "POST",
      "purpose": "Generate ranked property suggestions enhanced by valuation intelligence, market comparables, trend analysis, location intelligence, and preference-aware recommendation logic.",
      "controls": [
        "KYC state check",
        "explainability payload",
        "consent receipt",
        "privacy tier enforcement",
        "why-this-rank explanation payload",
        "ISO/IEC 5259 data-quality scorecard",
        "ISO/IEC 42001 oversight state",
        "ranking fairness diagnostics"
      ]
    },
    {
      "path": "/v1/insurance/recommendations/evaluate",
      "method": "POST",
      "purpose": "Analyze user profile, property type, and transaction context to recommend homeowners, title, landlord, and life-related insurance options using ACORD-informed payloads and NAIC-aligned privacy/security controls.",
      "controls": [
        "ACORD payload schema validation",
        "purpose-bound consent receipt",
        "encrypted carrier exchange",
        "role-based quote access",
        "NAIC-aligned privacy and incident logging"
      ]
    },
    {
      "path": "/v1/residency/eligibility/evaluate",
      "method": "POST",
      "purpose": "Evaluate residency-by-investment or relocation eligibility using jurisdiction rules, applicant finances, property value, document readiness, and compliance gates.",
      "controls": [
        "KYC state check",
        "AML source-of-funds review",
        "jurisdiction rule versioning",
        "ISO/IEC 27701 privacy minimization",
        "document completeness workflow",
        "manual compliance sign-off for exceptions"
      ]
    },
    {
      "path": "/v1/transactions/deal-intelligence",
      "method": "POST",
      "purpose": "Run pricing strategy, negotiation insights, document validation, and deal risk scoring for an active transaction.",
      "controls": [
        "ISO/IEC 27001 access governance",
        "stage-order integrity enforcement",
        "document hash verification",
        "tamper-evident audit log",
        "manual approval checkpoints"
      ]
    },
    {
      "path": "/v1/transactions/workflow-integrity",
      "method": "POST",
      "purpose": "Validate stage sequencing, evidence completeness, approval segregation, and release readiness for transaction workflows.",
      "controls": [
        "workflow replay capability",
        "segregation of duties",
        "immutable event stream",
        "exception escalation"
      ]
    },
    {
      "path": "/v1/transactions/documents/validate",
      "method": "POST",
      "purpose": "Check diligence, title, financing, disclosure, and closing documents for completeness and execution risk.",
      "controls": [
        "records retention",
        "document checksum verification",
        "privacy-aware redaction",
        "approval traceability"
      ]
    },
    {
      "path": "/v1/transactions/compliance/release",
      "method": "POST",
      "purpose": "Run final release and resilience gates for transactions while attaching ISO/IEC 27001 and ISO 22301 evidence.",
      "controls": [
        "BCDR tier mapping",
        "RTO/RPO checkpoint",
        "incident escalation linkage",
        "immutable evidence",
        "policy versioning"
      ]
    },
    {
