{
  "service": "EstateOS Unified Intelligence API",
  "version": "0.1.0",
  "azure_pattern": {
    "entrypoints": ["Azure API Management", "Azure Front Door", "Private endpoints"],
    "runtime": ["Azure Kubernetes Service", "Azure Container Apps", "Azure Functions"],
    "data": ["Azure SQL", "Cosmos DB", "Data Lake Storage Gen2", "Azure AI Search"],
    "security": ["Microsoft Entra ID", "Key Vault", "Defender for Cloud", "Microsoft Sentinel"]
  },
  "endpoints": [
    {
      "path": "/v1/intelligence/route",
      "method": "POST",
      "purpose": "Detect user intent and select MoE experts for a session.",
      "controls": ["JWT auth", "RBAC", "PII minimization", "audit log"]
    },
    {
      "path": "/v1/properties/recommendations",
      "method": "POST",
      "purpose": "Generate guided property discovery and pricing recommendations.",
      "controls": ["KYC state check", "explainability payload", "consent receipt"]
    },
    {
      "path": "/v1/rbi/eligibility",
      "method": "POST",
      "purpose": "Evaluate residency-by-investment pathways by jurisdiction.",
      "controls": ["sanctions screening", "jurisdiction rules engine", "records retention"]
    },
    {
      "path": "/v1/insurance/options",
      "method": "POST",
      "purpose": "Return coverage options and ACORD-aligned intake data.",
      "controls": ["licensing check", "carrier access policy", "PII tokenization"]
    },
    {
      "path": "/v1/compliance/release",
      "method": "POST",
      "purpose": "Run final release gate for decisions and generate audit evidence.",
      "controls": ["immutable evidence", "human approval", "policy versioning"]
    }
  ]
}
