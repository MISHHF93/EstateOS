{
  "service": "EstateOS Unified Intelligence API",
  "version": "0.7.0",
  "azure_pattern": {
    "entrypoints": [
      "Azure API Management",
      "Azure Front Door",
      "Private endpoints"
    ],
    "runtime": [
      "Azure Kubernetes Service",
      "Azure Container Apps",
      "Azure Functions"
    ],
    "data": [
      "Azure SQL",
      "Cosmos DB",
      "Data Lake Storage Gen2",
      "Azure AI Search"
    ],
    "security": [
      "Microsoft Entra External ID",
      "Key Vault",
      "Defender for Cloud",
      "Microsoft Purview",
      "Microsoft Sentinel"
    ]
  },
  "identity_and_access": {
    "frontend_capture": [
      "investor_type",
      "location",
      "financial_intent",
      "residency_goal",
      "consent_scope",
      "privacy_preferences",
      "deal_participants",
      "transaction_stage"
    ],
    "trust_controls": [
      "OIDC/OAuth2 with step-up MFA",
      "RBAC plus entitlement checks",
      "KYC status propagation",
      "AML risk scoring",
      "sanctions screening status",
      "purpose-bound privacy tiers",
      "segregation of duties for approvals"
    ],
    "router_contract": {
      "required_headers": [
        "Authorization",
        "x-correlation-id",
        "x-journey-stage",
        "x-transaction-id"
      ],
      "required_context": [
        "subject_id",
        "auth_assurance_level",
        "mfa_completed",
        "rbac_roles",
        "entitlements",
        "kyc_status",
        "aml_risk",
        "sanctions_status",
        "privacy_tier"
      ]
    }
  },
  "schemas": {
    "ProfileContext": {
      "type": "object",
      "required": [
        "role",
        "investor_type",
        "location",
        "financial_intent",
        "residency_goal",
        "consent_scope",
        "privacy_preferences"
      ]
    },
    "IdentityTrustContext": {
      "type": "object",
      "required": [
        "subject_id",
        "auth_assurance_level",
        "mfa_completed",
        "rbac_roles",
        "entitlements",
        "kyc_status",
        "aml_risk",
        "sanctions_status",
        "privacy_tier"
      ]
    },
    "DecisionRelease": {
      "type": "object",
      "required": [
        "recommendation",
        "release_status",
        "selected_experts",
        "ranked_recommendations",
        "governance_status",
        "explanation",
        "policy_gates",
        "audit_trail"
      ]
    },
    "RankedRecommendation": {
      "type": "object",
      "required": [
        "candidate_id",
        "title",
        "geography",
        "composite_score",
        "confidence",
        "expert_contributions",
        "valuation_band",
        "comparable_summary",
        "trend_signal",
        "location_intelligence",
        "recommendation_rationale",
        "why",
        "investment_insight",
        "visa_pathway",
        "insurance_option"
      ]
    },
    "TransactionCase": {
      "type": "object",
      "required": [
        "transaction_id",
        "deal_name",
        "deal_type",
        "jurisdiction",
        "stage",
        "purchase_price",
        "target_price",
        "financing_ratio",
        "requested_documents",
        "workflow_stages",
        "bcdr_tier"
      ]
    },
    "TransactionDecision": {
      "type": "object",
      "required": [
        "transaction",
        "pricing_strategy",
        "negotiation_insight",
        "document_validation",
        "risk_scoring",
        "overall_risk_score",
        "risk_rating",
        "release_status",
        "workflow_integrity",
        "compliance_controls",
        "audit_trail",
        "recommendations"
      ]
    },
    "WorkflowIntegrity": {
      "type": "object",
      "required": [
        "sequential_integrity",
        "audit_status",
        "immutable_event_chain",
        "continuity_mode",
        "continuity_notes"
      ]
    },
    "GovernanceStatus": {
      "type": "object",
      "required": [
        "framework",
        "status",
        "controls",
        "explanation"
      ]
    },
    "ResidencyApplicantProfile": {
      "type": "object",
      "required": [
        "applicant_id",
        "citizenship_country",
        "current_country",
        "target_jurisdiction",
        "household_size",
        "dependents",
        "annual_income",
        "liquid_assets",
        "property_budget",
        "property_value",
        "source_of_funds_verified",
        "criminal_record_clear",
        "health_insurance_ready",
        "documents_on_file"
      ]
    },
    "ResidencyEligibilityDecision": {
      "type": "object",
      "required": [
        "program",
        "jurisdiction",
        "pathway_type",
        "eligibility_status",
        "eligibility_score",
        "rule_checks",
        "document_checks",
        "compliance_workflow",
        "kyc_aml_summary",
        "privacy_summary",
        "explanation",
        "standards_alignment"
      ]
    },
    "ResidencyRuleCheck": {
      "type": "object",
      "required": [
        "name",
        "status",
        "detail"
      ]
    },
    "ResidencyDocumentCheck": {
      "type": "object",
      "required": [
        "document",
        "status",
        "detail"
      ]
    },
    "ResidencyComplianceWorkflowStep": {
      "type": "object",
      "required": [
        "step",
        "owner",
        "status",
        "detail"
      ]
    },
    "InsuranceApplicantProfile": {
      "type": "object",
      "required": [
        "applicant_id",
        "persona",
        "property_type",
        "occupancy",
        "transaction_context",
        "property_jurisdiction",
        "estimated_property_value",
        "mortgage_amount",
        "household_size",
        "dependents",
        "landlord_exposure",
        "title_required",
        "life_priority",
        "privacy_consent"
      ]
    },
    "ACORDCoverageRequest": {
      "type": "object",
      "required": [
        "line_of_business",
        "acord_form",
        "coverage_type",
        "insured_amount",
        "deductible",
        "notes"
      ]
    },
    "InsuranceRecommendation": {
      "type": "object",
      "required": [
        "coverage_type",
        "recommendation_level",
        "policy_form",
        "premium_estimate",
        "rationale",
        "acord_payload_refs"
      ]
    },
    "SecureExchangeControl": {
      "type": "object",
      "required": [
        "control",
        "status",
        "detail"
      ]
    },
    "InsuranceDecision": {
      "type": "object",
      "required": [
        "applicant",
        "acord_parties",
        "acord_coverages",
        "recommendations",
        "secure_exchange_controls",
        "naic_privacy_summary",
        "secure_exchange_summary",
        "release_status",
        "explanation",
        "standards_alignment"
      ]
    }
  },
  "endpoints": [
    {
      "path": "/v1/identity/profile-context",
      "method": "POST",
      "purpose": "Capture frontend profile, privacy, and trust context before MoE routing.",
      "controls": [
        "OIDC session binding",
        "step-up MFA",
        "consent receipt",
        "PII classification",
        "audit log"
      ]
    },
    {
      "path": "/v1/intelligence/route",
      "method": "POST",
      "purpose": "Detect user intent and select MoE experts using profile and identity trust context.",
      "controls": [
        "JWT auth",
        "RBAC",
        "entitlement check",
        "PII minimization",
        "audit log",
        "ranked expert contribution trace"
      ]
    },
    {
      "path": "/v1/properties/recommendations",
      "method": "POST",
      "purpose": "Generate ranked property suggestions enhanced by valuation intelligence, market comparables, trend analysis, location intelligence, and preference-aware recommendation logic.",
      "controls": [
        "KYC state check",
        "explainability payload",
        "consent receipt",
        "privacy tier enforcement",
        "why-this-rank explanation payload",
        "ISO/IEC 5259 data-quality scorecard",
        "ISO/IEC 42001 oversight state",
        "ranking fairness diagnostics"
      ]
    },
    {
      "path": "/v1/insurance/recommendations/evaluate",
      "method": "POST",
      "purpose": "Analyze user profile, property type, and transaction context to recommend homeowners, title, landlord, and life-related insurance options using ACORD-informed payloads and NAIC-aligned privacy/security controls.",
      "controls": [
        "ACORD payload schema validation",
        "purpose-bound consent receipt",
        "encrypted carrier exchange",
        "role-based quote access",
        "NAIC-aligned privacy and incident logging"
      ]
    },
    {
      "path": "/v1/residency/eligibility/evaluate",
      "method": "POST",
      "purpose": "Evaluate residency-by-investment or relocation eligibility using jurisdiction rules, applicant finances, property value, document readiness, and compliance gates.",
      "controls": [
        "KYC state check",
        "AML source-of-funds review",
        "jurisdiction rule versioning",
        "ISO/IEC 27701 privacy minimization",
        "document completeness workflow",
        "manual compliance sign-off for exceptions"
      ]
    },
    {
      "path": "/v1/transactions/deal-intelligence",
      "method": "POST",
      "purpose": "Run pricing strategy, negotiation insights, document validation, and deal risk scoring for an active transaction.",
      "controls": [
        "ISO/IEC 27001 access governance",
        "stage-order integrity enforcement",
        "document hash verification",
        "tamper-evident audit log",
        "manual approval checkpoints"
      ]
    },
    {
      "path": "/v1/transactions/workflow-integrity",
      "method": "POST",
      "purpose": "Validate stage sequencing, evidence completeness, approval segregation, and release readiness for transaction workflows.",
      "controls": [
        "workflow replay capability",
        "segregation of duties",
        "immutable event stream",
        "exception escalation"
      ]
    },
    {
      "path": "/v1/transactions/documents/validate",
      "method": "POST",
      "purpose": "Check diligence, title, financing, disclosure, and closing documents for completeness and execution risk.",
      "controls": [
        "records retention",
        "document checksum verification",
        "privacy-aware redaction",
        "approval traceability"
      ]
    },
    {
      "path": "/v1/transactions/compliance/release",
      "method": "POST",
      "purpose": "Run final release and resilience gates for transactions while attaching ISO/IEC 27001 and ISO 22301 evidence.",
      "controls": [
        "BCDR tier mapping",
        "RTO/RPO checkpoint",
        "incident escalation linkage",
        "immutable evidence",
        "policy versioning"
      ]
    }
  ]
}